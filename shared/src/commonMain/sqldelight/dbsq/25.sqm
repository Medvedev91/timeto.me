import kotlin.Int;

ALTER TABLE IntervalSq
RENAME TO temp;

CREATE TABLE IntervalSq (
    id INTEGER AS Int NOT NULL PRIMARY KEY AUTOINCREMENT,
    time INTEGER AS Int NOT NULL,
    activity_id INTEGER AS Int NOT NULL,
    note TEXT -- Nullable!
);

INSERT INTO IntervalSq
SELECT NULL, id, activity_id, note
FROM temp;

CREATE INDEX IntervalSq_time ON IntervalSq(time);

DROP TABLE temp;
